# Halfsaid — copy to .env and fill in.
# Reconstruction runs through OpenRouter (openai-compatible). Without a key the
# board still runs in "demo mode" (a literal word-join), so you can build the UI
# before wiring credentials. Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional — which OpenRouter model reconstructs the sentences. Any OpenRouter
# slug works. Defaults to openai/gpt-4o-mini.
# Examples: anthropic/claude-3.7-sonnet · openai/gpt-4o · google/gemini-2.0-flash-001
OPENROUTER_MODEL=

# Optional — own-voice (Phase 3). Without it, sentences speak in the browser's
# built-in voice. With it, you can speak in a chosen or cloned voice.
# Note: ElevenLabs voice cloning requires a paid plan.
ELEVENLABS_API_KEY=
