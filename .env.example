# Halfsaid frontend (deploys to Vercel). The backend — which holds the
# OpenRouter + ElevenLabs keys and the /api routes — runs separately on Fly.
# See server/.env.example for the backend secrets.
#
# Point the frontend at the backend:
#   local dev:  PUBLIC_API_URL=http://localhost:8080
#   production: PUBLIC_API_URL=https://<your-fly-app>.fly.dev
PUBLIC_API_URL=
