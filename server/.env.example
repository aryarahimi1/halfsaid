# Halfsaid API — secrets live here (on Fly: `fly secrets set KEY=value`).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
ELEVENLABS_API_KEY=

# Comma-separated browser origins allowed to call this API (your Vercel URL).
# Empty = allow any origin (fine for a demo). Example:
# CORS_ORIGINS=https://halfsaid.vercel.app,http://localhost:5173
CORS_ORIGINS=
